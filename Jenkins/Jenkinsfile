pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('List Files') {
            steps {
                sh 'ls -la'
            }
        }

        // ==================
        // PYTHON CODE CHECKS
        // ==================
        stage('Check Python Code') {
            steps {
                script {
                    echo "=========================================="
                    echo "🐍 Python Code Quality Check"
                    echo "=========================================="
                }
                sh '''
                    pip install -r requirements.txt
                    pip install pytest
                    pytest tests/ --verbose || echo "⚠️  No tests yet"
                '''
            }
        }

        // ==================
        // BUILD DOCKER IMAGES
        // ==================
        stage('Build Backend Image') {
            steps {
                script {
                    echo "=========================================="
                    echo "🔨 Building Backend Docker Image"
                    echo "=========================================="
                }
                sh '''
                    docker build -t connecthub-backend:latest .
                    echo "✅ Backend image built successfully"
                '''
            }
        }

        stage('Test Backend Image') {
            steps {
                script {
                    echo "Testing: Can backend container start?"
                }
                sh '''
                    docker run --rm connecthub-backend:latest python --version
                    echo "✅ Backend container can execute commands"
                '''
            }
        }

        stage('Verify Backend Structure') {
            steps {
                sh '''
                    docker run --rm connecthub-backend:latest ls -la /app
                    echo "✅ Backend app files exist"
                '''
            }
        }

        stage('Build Frontend Image') {
            steps {
                script {
                    echo "=========================================="
                    echo "🔨 Building Frontend Docker Image"
                    echo "=========================================="
                }
                sh '''
                    docker build -t connecthub-frontend:latest ./frontend-service
                    echo "✅ Frontend image built successfully"
                '''
            }
        }

        // ==================
        // INTEGRATION TESTS
        // ==================
        stage('Tag Images for docker-compose') {
            steps {
                script {
                    echo "=========================================="
                    echo "🏷️  Tagging Images for docker-compose"
                    echo "=========================================="
                }
                sh '''
                    # Tag images to match docker-compose expectations
                    docker tag connecthub-backend:latest tomernos/connecthub-backend:latest
                    docker tag connecthub-frontend:latest tomernos/connecthub-frontend:latest
                    
                    echo "✅ Images tagged for docker-compose"
                    docker images | grep connecthub
                '''
            }
        }

        stage('Start Services with docker-compose') {
            steps {
                script {
                    echo "=========================================="
                    echo "🚀 Starting All Services"
                    echo "=========================================="
                }
                sh '''
                    echo "Starting services with docker-compose"
                    docker compose up -d
                    echo "Waiting for containers to start..."
                    sleep 10
                    docker compose ps
                '''
            }
        }

        stage('Wait for Service Health') {
            steps {
                script {
                    echo "=========================================="
                    echo "🏥 Checking Service Health"
                    echo "=========================================="
                }
                sh '''
                    echo "=== Running Containers ==="
                    docker ps
                    echo ""
                    echo "=== Container Health ==="
                    docker ps --format "table {{.Names}}\\t{{.Status}}"
                '''
            }
        }

        stage('Test Health Endpoints') {
            steps {
                script {
                    echo "Testing backend health endpoint..."
                }
                sh '''
                    curl -f http://localhost:5000/health || exit 1
                    echo "✅ Health check passed"
                '''
            }
        }

        stage('Test Ready Endpoint') {
            steps {
                script {
                    echo "Testing readiness probe endpoint..."
                }
                sh '''
                    curl -f http://localhost:5000/ready || exit 1
                    echo "✅ Readiness check passed"
                '''
            }
        }

        stage('Test API Endpoints') {
            steps {
                script {
                    echo "Testing API functionality..."
                }
                sh '''
                    curl -f http://localhost:5000/ | grep "ConnectHub" || exit 1
                    echo "✅ API is responding correctly"
                '''
            }
        }

        // ==================
        // CVE SECURITY SCAN
        // ==================
        stage('CVE Scan - Backend') {
            steps {
                script {
                    echo "=========================================="
                    echo "🔒 CVE Security Scan - Backend"
                    echo "=========================================="
                }
                sh '''
                    docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
                    aquasec/trivy image --severity HIGH,CRITICAL connecthub-backend:latest
                '''
            }
        }

        stage('CVE Scan - Frontend') {
            steps {
                script {
                    echo "=========================================="
                    echo "🔒 CVE Security Scan - Frontend"
                    echo "=========================================="
                }
                sh '''
                    docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
                    aquasec/trivy image --severity HIGH,CRITICAL connecthub-frontend:latest
                '''
            }
        }
    }

    post {
        always {
            script {
                echo "=========================================="
                echo "🧹 Cleanup"
                echo "=========================================="
            }
            sh '''
                # Show logs if something failed
                if [ $? -ne 0 ]; then
                    echo "=== Backend Logs ==="
                    docker logs connecthub-backend-api || true
                    echo ""
                    echo "=== Database Logs ==="
                    docker logs connecthub-database || true
                fi
                
                # Always cleanup services
                docker compose down -v
                echo "✅ Services stopped and cleaned"
            '''
        }
        success {
            echo "=========================================="
            echo "✅ CI Pipeline Completed Successfully!"
            echo "=========================================="
        }
        failure {
            echo "=========================================="
            echo "❌ CI Pipeline Failed!"
            echo "=========================================="
        }
    }
}